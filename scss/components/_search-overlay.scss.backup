// Search Overlay - Unified with Header
.search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.97);
    backdrop-filter: blur(8px);
    z-index: 9999; // Below header (header is 10000)
    display: none;
    opacity: 0;
    transition: opacity 0.25s ease;
    padding-top: 90px; // Space for sticky header

    @media (max-width: 768px) {
        padding-top: 70px;
    }

    &.active {
        display: block;
        opacity: 1;
        animation: fadeIn 0.25s ease;
    }

    // Centered Container
    .search-overlay__container {
        width: 100%;
        max-width: 850px;
        margin: 0 auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 110px);

        @media (max-width: 768px) {
            padding: 15px;
            max-height: calc(100vh - 90px);
        }
    }

    // Header with Close Button
    .search-overlay__header {
        padding-bottom: 16px;
        display: flex;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    // Close Button
    .search-overlay__close {
        width: 38px;
        height: 38px;
        background: rgba(237, 50, 55, 0.1);
        border: 1px solid rgba(237, 50, 55, 0.3);
        border-radius: 8px;
        color: #ED3237;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;

        &:hover {
            background: rgba(237, 50, 55, 0.2);
            border-color: #ED3237;
        }
    }

    // Scrollable Content
    .search-overlay__content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 8px;

        &::-webkit-scrollbar {
            width: 6px;
        }

        &::-webkit-scrollbar-track {
            background: transparent;
        }

        &::-webkit-scrollbar-thumb {
            background: rgba(237, 50, 55, 0.3);
            border-radius: 3px;

            &:hover {
                background: rgba(237, 50, 55, 0.5);
            }
        }
    }

    // Quick Links Section
    .search-quick-links {
        margin-bottom: 28px;

        h3 {
            color: #888;
            font-size: 0.8rem;
            font-weight: 600;
            margin: 0 0 12px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .quick-links-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .quick-link {
            padding: 8px 14px;
            background: rgba(26, 5, 6, 0.6);
            border: 1px solid rgba(237, 50, 55, 0.2);
            border-radius: 6px;
            color: #ccc;
            text-decoration: none;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 6px;

            i {
                font-size: 0.8rem;
                opacity: 0.6;
            }

            &:hover {
                background: rgba(237, 50, 55, 0.15);
                border-color: #ED3237;
                color: #fff;
                transform: translateY(-1px);
            }
        }
    }

    // Recent Searches
    .search-recent {
        margin-bottom: 28px;
        display: none;

        &.has-items {
            display: block;
        }

        h3 {
            color: #888;
            font-size: 0.8rem;
            font-weight: 600;
            margin: 0 0 10px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .recent-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .recent-tag {
            padding: 6px 12px;
            background: rgba(26, 5, 6, 0.5);
            border: 1px solid rgba(237, 50, 55, 0.15);
            border-radius: 6px;
            color: #aaa;
            text-decoration: none;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;

            i {
                font-size: 0.75rem;
                opacity: 0.5;
            }

            &:hover {
                background: rgba(237, 50, 55, 0.1);
                border-color: #ED3237;
                color: #fff;
            }

            .remove-recent {
                margin-left: 2px;
                opacity: 0;
                transition: opacity 0.2s ease;
            }

            &:hover .remove-recent {
                opacity: 1;
            }
        }
    }

    // Trending Searches
    .search-trending {
        margin-bottom: 32px;

        h3 {
            color: #888;
            font-size: 0.8rem;
            font-weight: 600;
            margin: 0 0 12px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 6px;

            i {
                color: #ED3237;
                font-size: 0.9rem;
            }
        }

        .trending-items {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 10px;

            @media (max-width: 768px) {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .trending-item {
            padding: 12px 14px;
            background: rgba(26, 5, 6, 0.6);
            border: 1px solid rgba(237, 50, 55, 0.2);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 10px;

            &:hover {
                background: rgba(237, 50, 55, 0.15);
                border-color: #ED3237;
                transform: translateY(-2px);
            }

            .trending-number {
                font-size: 1.1rem;
                font-weight: 700;
                color: #ED3237;
                width: 28px;
                text-align: center;
            }

            .trending-text {
                font-size: 0.9rem;
                color: #ccc;
                flex: 1;
            }
        }
    }

    // Search Results
    .search-results {
        h3 {
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            margin: 0 0 16px 0;

            span {
                color: #ED3237;
            }
        }

        .results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 14px;

            @media (max-width: 768px) {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
            }
        }

        .result-card {
            background: rgba(26, 5, 6, 0.6);
            border: 1px solid rgba(237, 50, 55, 0.2);
            border-radius: 10px;
            overflow: hidden;
            text-decoration: none;
            transition: all 0.2s ease;

            &:hover {
                border-color: #ED3237;
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(237, 50, 55, 0.2);
            }

            .result-image {
                width: 100%;
                height: 160px;
                object-fit: cover;
                background: rgba(12, 3, 4, 0.8);

                @media (max-width: 768px) {
                    height: 140px;
                }
            }

            .result-content {
                padding: 12px;

                .result-title {
                    color: #fff;
                    font-size: 0.9rem;
                    font-weight: 600;
                    margin: 0 0 6px 0;
                    display: -webkit-box;
                    -webkit-line-clamp: 2;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                    line-height: 1.3;
                }

                .result-price {
                    color: #ED3237;
                    font-size: 1.05rem;
                    font-weight: 700;
                    margin: 6px 0;
                }

                .result-rating {
                    display: flex;
                    align-items: center;
                    gap: 6px;
                    font-size: 0.8rem;

                    .stars {
                        color: #FFB800;
                        font-size: 0.75rem;
                    }

                    .count {
                        color: #666;
                    }
                }
            }
        }

        .no-results {
            text-align: center;
            padding: 40px 20px;
            grid-column: 1 / -1;

            .no-results-icon {
                font-size: 3.5rem;
                color: rgba(237, 50, 55, 0.3);
                margin-bottom: 16px;
            }

            h4 {
                color: #fff;
                font-size: 1.2rem;
                margin: 0 0 8px 0;
            }

            p {
                color: #888;
                font-size: 0.95rem;
                margin: 0;
            }
        }

        .view-all-results {
            margin-top: 20px;
            text-align: center;

            .btn-view-all {
                padding: 12px 28px;
                background: linear-gradient(135deg, #ED3237, #FF6B00);
                border: none;
                border-radius: 8px;
                color: #fff;
                font-size: 0.95rem;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 8px;

                &:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(237, 50, 55, 0.3);
                }
            }
        }
    }

    // Loading State
    .search-loading {
        text-align: center;
        padding: 50px 20px;

        .loading-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(237, 50, 55, 0.2);
            border-top-color: #ED3237;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }

        p {
            color: #888;
            font-size: 0.9rem;
        }
    }
}

// Animations
@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

// Prevent body scroll when overlay is open
body.search-overlay-open {
    overflow: hidden;
}
